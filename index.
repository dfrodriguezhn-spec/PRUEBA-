<!DOCTYPE html>
<html>
<body>
    <button id="miBoton">Enviar Prueba a Sheets</button>

    <script>
        document.getElementById('miBoton').addEventListener('click', () => {
            // PEGA TU URL DE GOOGLE AQUÍ ABAJO (entre las comillas)
            const url = "TU_URL_DE_GOOGLE_AQUI";

            fetch(url, {
                method: "POST",
                mode: "no-cors"
            })
            .then(() => alert("¡Enviado! Revisa tu hoja."))
            .catch(error => alert("Error: " + error));
        });
    </script>
</body>
</html>
